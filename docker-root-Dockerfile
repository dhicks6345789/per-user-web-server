FROM ubuntu:24.04

# Avoid prompts during installation
ENV DEBIAN_FRONTEND=noninteractive

# Get updated installation repository lists.
RUN apt-get update

# Install Xfce, TigerVNC, and basic tools.
RUN apt-get install -y xfce4 xfce4-goodies tigervnc-standalone-server dbus-x11 x11-xserver-utils sudo curl

# For some reason, we seem to have to update repository lists again to avoid errors.
RUN apt-get update

# Update and install software-properties-common
RUN apt-get install -y software-properties-common
# Add the Chromium Team PPA
RUN add-apt-repository -y ppa:canonical-chromium-builds/stage
# Install the Chromium web browser.
RUN apt-get update
RUN apt-get install -y chromium-browser

# Install a Python development environment.
RUN apt-get install -y python3 python3-pip
# The Pandas data-processing library.
RUN apt-get install -y python3-pandas

# Clear up apt lists.
# RUN apt-get clean && rm -rf /var/lib/apt/lists/*
