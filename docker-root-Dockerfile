FROM debian:latest

# Avoid prompts during installation
ENV DEBIAN_FRONTEND=noninteractive

# Get updated installation repository lists.
RUN apt-get update

# Update and install Xfce4, VNC server, and dependencies
RUN apt-get install -y xfce4 xfce4-goodies tigervnc-standalone-server dbus-x11 x11-xserver-utils

# Set up VNC configuration
RUN mkdir -p ~/.vnc && echo "#!/bin/sh\nunset SESSION_MANAGER\nunset DBUS_SESSION_BUS_ADDRESS\nstartxfce4 &" > ~/.vnc/xstartup && chmod +x ~/.vnc/xstartup

