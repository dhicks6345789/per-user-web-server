FROM {{DOCKERROOT_DOCKER_IMAGE}}

RUN cd /root && git clone https://github.com/ukfootprint/class-timetabler.git

RUN rm /root/class-timetabler/backend/venv/bin/python
RUN rm /root/class-timetabler/backend/venv/bin/python3
RUN rm /root/class-timetabler/backend/venv/bin/python3.12
RUN rm /root/class-timetabler/backend/venv/bin/python3.13
RUN apt-get install -y python3-venv

## Install the Class Timetabler backend.
RUN cd /root/class-timetabler/backend && python3 -m venv venv && source venv/bin/activate && pip install -r requirements.txt

## Install the Class Timetabler frontend.
RUN cd /root/class-timetabler/frontend && npm install

# Expose port 3000 for the frontend, Pangolin can direct traffic to this port.
EXPOSE 3000
