FROM {{DOCKERROOT_DOCKER_IMAGE}}

RUN cd /root
RUN git clone https://github.com/ukfootprint/class-timetabler.git

# Install the Class Timetabler backend.
RUN cd /root/class-timetabler/backend
# Create virtual environment and install dependencies.
RUN python -m venv venv
RUN source venv/bin/activate
RUN pip install -r requirements.txt

RUN cd /root/class-timetabler/frontend
RUN npm install

# Expose port 3000 for the frontend, Pangolin can direct traffic to this port.
EXPOSE 3000
