# Use the latest Debian base image, the slim version as we just want a minimal container that can run a small GO application.
FROM debian:latest-slim

# Prevent interactive prompts during installation
ENV DEBIAN_FRONTEND=noninteractive

# Get updated installation repository lists.
RUN apt-get update

COPY per-user-web-server/rcloneGUI/rcloneGUI /usr/local/bin/rcloneGUI
EXPOSE 8080
