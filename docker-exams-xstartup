#!/bin/sh
unset SESSION_MANAGER
unset DBUS_SESSION_BUS_ADDRESS

# Start the XFCE4 desktop environment.
startxfce4 &



if [ ! -d ".wine/drive_c/Program Files/ExamPad+" ]; then
  # Run the ExamPad+ (Windows) installer.
  wine msiexec /i ExamPad+.msi /qb
fi

if [ ! -f ".wine/drive_c/windows/Fonts/times.ttf" ]; then
  # Use Winetricks to install "corefonts".
  winetricks corefonts
fi

wine ".wine/drive_c/Program Files/ExamPad+/ExamPad+.exe" &



# Wait for the process to exist.
while ! pgrep -x "xfce4-panel" > /dev/null; do
    sleep 0.5
done
# Wait for the panel to actually map a window to the screen.
while [ -z "$(xprop -name xfce4-panel 2>/dev/null)" ]; do
    sleep 0.5
done

echo > ~/xfce4Log.txt

xfconf-query -c xfce4-desktop -p /desktop-icons/style -n -t int -s 0 >> ~/xfce4Log.txt
xfconf-query -c xfwm4 -p /general/workspace_count -s 1 >> ~/xfce4Log.txt

xfconf-query -c xfwm4 -p /general/use_compositing -n -t bool -s true >> ~/xfce4Log.txt

xfconf-query -c xfce4-panel -p /panels/panel-1/plugin-ids -r >> ~/xfce4Log.txt
xfconf-query -c xfce4-panel -p /panels/panel-1/autohide-behavior -n -t int -s 2 >> ~/xfce4Log.txt
xfconf-query -c xfce4-panel -p /panels/panel-1/background-alpha -n -t int -s 0 >> ~/xfce4Log.txt
xfconf-query -c xfce4-panel -p /panels/panel-1/background-style -n -t int -s 1 >> ~/xfce4Log.txt
xfconf-query -c xfce4-panel -p /panels/panel-1/background-rgba -n -t double -s 0 -a -t double -s 0 -a -t double -s 0 -a -t double -s 0 >> ~/xfce4Log.txt

xfconf-query -c xfce4-panel -p /panels/panel-2/plugin-ids -r >> ~/xfce4Log.txt
xfconf-query -c xfce4-panel -p /panels/panel-2/autohide-behavior -n -t int -s 2 >> ~/xfce4Log.txt
xfconf-query -c xfce4-panel -p /panels/panel-2/background-alpha -n -t int -s 0 >> ~/xfce4Log.txt
xfconf-query -c xfce4-panel -p /panels/panel-2/background-style -n -t int -s 1 >> ~/xfce4Log.txt
xfconf-query -c xfce4-panel -p /panels/panel-2/background-rgba -n -t double -s 0 -a -t double -s 0 -a -t double -s 0 -a -t double -s 0 >> ~/xfce4Log.txt

xfce4-panel -r >> ~/xfce4Log.txt

bash /home/$1/autoResize.sh >> ~/xfce4Log.txt &



echo "End of xstartup" >> ~/xfce4Log.txt

# Start a constant "null" process so the container doesn't exit.
tail -f /dev/null
