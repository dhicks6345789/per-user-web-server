FROM {{DOCKERWINE_DOCKER_IMAGE}}

# Update apt repository lists again.
RUN apt-get update

RUN apt-get install -y openbox obconf x11-xserver-utils

# Copy the (Windows) installer for ExamPad+ into the Docker image.
COPY ExamPad+.msi /root/ExamPad+.msi

# Copy in the startup scripts. Further setup is done after startup by these scripts rather than here as we create a separate named user in each container instance and need to
# match up UIDs with the host, which we don't know until container creation time.
COPY per-user-web-server/docker-exams-xstartup /root/docker-exams-xstartup
COPY per-user-web-server/docker-exams-root-startup.sh /root/docker-exams-root-startup.sh
COPY per-user-web-server/docker-exams-user-startup.sh /root/docker-exams-user-startup.sh
