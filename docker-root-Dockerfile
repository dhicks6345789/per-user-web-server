# Use the latest Debian base image. This is the base image for our images that provide user desktop
# interfaces, complete with all the tools a developer might need / want, so we're using the
# full-feature version rather than an optomised "slim" image.
FROM debian:latest

# Prevent interactive prompts during installation
ENV DEBIAN_FRONTEND=noninteractive

# Get updated installation repository lists.
RUN apt-get update

# Install some basic utilities.
RUN apt-get install -y curl sudo wget nano procps unzip p7zip

# Install rclone, a tool for handling cloud / remote file systems. Debian does include a packaged version of rclone,
# but as of May 2026 that version is older than the one we want to use - we want a version with the built-in GUI capability.
# Therefore, we install using rclone's own install script rather than via apt.
RUN curl https://rclone.org/install.sh | bash



# Install a Python development environment. Note: we can't generally use Python's "pip" package manager here, as Debian generally wants to install system-wide Python packages itself.
# Therefore, we generally wind up using the Debian package of common Python libraries, some of which can be a few versions behind the most current.
RUN apt-get install -y python3 python3-pip python3-venv

# Figure out and store the Python install path and version for later use.
RUN PYTHONPATH=$(python3 -c "import sys; print(sys.executable)") && echo "PYTHONPATH=$PYTHONPATH" > /tmp/dockerEnv && PYTHONVERSION=$(basename $PYTHONPATH) && echo "PYTHONVERSION=$PYTHONVERSION" >> /tmp/dockerEnv
RUN . /tmp/dockerEnv && echo "Python Path: $PYTHONPATH, Python Version: $PYTHONVERSION"

# The Google GenAI package - used to access Google's generative AI services.
# Not available as a Debian package to install via apt, so we install this in a globally-accessible Python venv - first we create the venv...
RUN python3 -m venv /opt/google_ai_env
# ...install the google-geni package...
RUN /opt/google_ai_env/bin/pip install google-genai
# ...and link it so all users can see it.
RUN . /tmp/dockerEnv && echo "/opt/google_ai_env/lib/$PYTHONVERSION/site-packages" | tee $PYTHONPATH/dist-packages/google_ai.pth
RUN rm /tmp/dockerEnv

# The Pandas data-processing library...
RUN apt-get install -y python3-pandas
# ...along with the OpenPYXL library to handle reading (modern) XLSX Excel files and the XLRD library to handle reading (older) XLS Excel files...
RUN apt-get install -y python3-openpyxl python3-xlrd
# ...and a whole separate module to write (modern) XLSX Excel files, including formating.
RUN apt-get install -y python3-xlsxwriter

# The Jinja2 Python templating library.
RUN apt-get install -y python3-jinja2

# The OpenCV Computer Vision library.
RUN apt-get install -y python3-opencv

# The NumPy multi-demensional array / maths library.
RUN apt-get install -y python3-numpy

# The Python Pil (or Pillow) image handling library.
RUN apt-get install -y python3-pil



# Install a Node.js development environment.
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
RUN apt-get install -y nodejs

# Install the Google Gemini command-line (CLI) tool - depends on Node.js.
RUN npm install -g @google/gemini-cli

# Install Hugo, a static-site building tool.
RUN apt-get install -y hugo
