FROM {{DOCKERROOT_DOCKER_IMAGE}}

# Update apt repository lists again.
RUN apt-get update

# Install a desktop environment - XFCE4 and TigerVNC.
RUN apt-get install -y xfce4 xfce4-goodies tigervnc-standalone-server tigervnc-common dbus-x11 x11-xserver-utils xterm

# Expose VNC port for VNC display ":1".
EXPOSE 5901

# Install the Chromium web browser.
RUN apt-get install -y chromium

## Install the Chrome web browser - note, this is not Chromium, but the actual Google Chrome release.
#RUN wget https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb
#RUN apt-get install -y ./google-chrome-stable_current_amd64.deb
#RUN rm google-chrome-stable_current_amd64.deb

# Install Inkscape, a vector graphics editing program.
RUN apt-get install -y inkscape

# Install GNU Gimp, a bitmap graphics editing program.
RUN apt-get install -y gimp

# Install the Microsoft .Net framework, v10 - needed for Pinta, but bound to be useful for other stuff.
RUN wget https://packages.microsoft.com/config/debian/13/packages-microsoft-prod.deb -O packages-microsoft-prod.deb
RUN dpkg -i packages-microsoft-prod.deb
RUN rm packages-microsoft-prod.deb
RUN apt-get update
RUN apt-get install -y dotnet-sdk-10.0

# Install some tools / frameworks needed for Pinta.
RUN apt-get install -y pkg-config
RUN apt-get install -y intltool
RUN apt-get install -y libadwaita-1-dev

# Install Pinta, a bitmap graphics editing program - a Linux clone of the popular Paint.NET Windows application. A simpler user interface than GNU Gimp (installed above), but more trouble to install.
RUN cd /usr/local/bin && wget https://github.com/PintaProject/Pinta/releases/download/3.1.1/pinta-3.1.1.tar.gz && tar xf pinta-3.1.1.tar.gz
RUN cd /usr/local/bin/pinta-3.1.1 && ./configure --prefix=/usr/local && dotnet build && cd .. && rm pinta-3.1.1.tar.gz
RUN chown root:root -R /usr/local/bin/pinta-3.1.1
RUN chmod a+rwx -R /usr/local/bin/pinta-3.1.1
COPY per-user-web-server/pinta.sh /usr/local/bin/pinta
RUN chmod a+x /usr/local/bin/pinta

# Install VSCode, Microsoft's IDE.
RUN wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor > packages.microsoft.gpg
RUN install -D -o root -g root -m 644 packages.microsoft.gpg /etc/apt/keyrings/packages.microsoft.gpg
RUN echo "deb [arch=amd64,arm64,armhf signed-by=/etc/apt/keyrings/packages.microsoft.gpg] https://packages.microsoft.com/repos/code stable main" > /etc/apt/sources.list.d/vscode.list
RUN rm -f packages.microsoft.gpg
RUN apt-get update
RUN apt-get install -y code



# To do: add shortcuts for:
# Pinta, Gimp, Inkscape, Chrome(ium), IDLE, Python Interactive Prompt, terminal, VSCode



# Copy in the startup scripts. Further setup is done after startup by these scripts rather than here as we create a separate named user in each container instance and need to
# match up UIDs with the host, which we don't know until container creation time.
COPY per-user-web-server/docker-desktop-xstartup /root/docker-desktop-xstartup
COPY per-user-web-server/docker-desktop-root-startup.sh /root/docker-desktop-root-startup.sh
COPY per-user-web-server/docker-desktop-user-startup.sh /root/docker-desktop-user-startup.sh

