[Unit]
Description=PUWSSessionManager
Wants=network-online.target
After=network-online.target
 
[Service]
Type=simple
ExecStart=/usr/local/bin/sessionManager
StandardOutput=append:/var/log/PUWSSessionManager/output.log
StandardError=inherit

ExecStop=kill $MAINPID
Restart=always
RestartSec=4
 
[Install]
WantedBy=default.target
